{
  "name": "proxymanager-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "import:substore": "tsx --env-file=.env.local scripts/import-from-substore.ts",
    "migrate:rules": "tsx --env-file=.env.local scripts/migrate-rules-into-hash.ts",
    "migrate:providers": "tsx --env-file=.env.local scripts/migrate-providers-into-hash.ts",
    "dedupe:rules": "tsx --env-file=.env.local scripts/dedupe-rules.ts",
    "fix:substore-dedup": "tsx --env-file=.env.local scripts/fix-sub-store-dedup.ts",
    "init:default-profile": "tsx --env-file=.env.local scripts/init-default-profile.ts",
    "vercel:dev": "vercel dev",
    "vercel:link": "vercel link",
    "vercel:deploy": "vercel deploy",
    "vercel:deploy:prod": "vercel deploy --prod",
    "vercel:env:pull": "vercel env pull .env.local"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@upstash/redis": "^1.38.0",
    "codemirror": "^6.0.2",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vercel": "^54.2.0",
    "vitest": "^4.1.6"
  }
}
